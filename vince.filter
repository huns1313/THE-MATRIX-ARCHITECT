// =============================================================================
// THE MATRIX ARCHITECT v14.8 // SYSTEM_OPTIMIZED // [GOD] HYUUNNS
// =============================================================================

// [0. GLOBAL CONFIGURATION & ALIASES]
// =============================================================================
Alias[MODE_NORMA]: 1   
Alias[MODE_NIGHT]: 2   
Alias[MODE_hellYa]: 3  

ItemDisplayFilterName[]: [n.] NORMA MODE
ItemDisplayFilterName[]: [nm.] NIGHT MODE
ItemDisplayFilterName[]: [hellYa!.] HELL MODE

// Re-populating RUNES (Stacked & Unstacked)
Alias[RUNES_NORMA]:  (r01 OR r02 OR r03 OR r04 OR r05 OR r06 OR r07 OR r08 OR r09 OR r01s OR r02s OR r03s OR r04s OR r05s OR r06s OR r07s OR r08s OR r09s)
Alias[RUNES_NIGHT]:  (r10 OR r11 OR r12 OR r13 OR r14 OR r15 OR r16 OR r17 OR r18 OR r10s OR r11s OR r12s OR r13s OR r14s OR r15s OR r16s OR r17s OR r18s)
Alias[RUNES_HELLYA]: (r19 OR r20 OR r21 OR r22 OR r23 OR r24 OR r25 OR r26 OR r27 OR r19s OR r20s OR r21s OR r22s OR r23s OR r24s OR r25s OR r26s OR r27s)
Alias[RUNES_GODLY]:  (r28 OR r29 OR r30 OR r31 OR r32 OR r33 OR r28s OR r29s OR r30s OR r31s OR r32s OR r33s)
// [1. SYSTEM RELEASE NOTES]
// [1. SYSTEM RELEASE NOTES]
// Targets Scroll of Identify (isc) in shops. 
// File MUST be saved in ANSI encoding with HD Text enabled to render these symbols.
ItemDisplay[isc SHOP]: %NAME%{%NAME%%NL%%TEAL%THE §  ¶  †  ‡  µ  ©  ®  ™  «  »   °  •  ·  ×  ¡  ¿  ¹  ²  ³  ¼  ½  ¾  ¢  £  ¥  |  _  · MATRIX%NL%%WHITE%----------------------------%NL%%GREEN%[hellYa!] Tier:%WHITE% Always Visible%NL%%GOLD%[GOD] Tier:%WHITE% Always Visible%NL%%WHITE%----------------------------}

/// =============================================================================
// [8. UNIQUES, SETS & RARES] - ALWAYS VISIBLE
// =============================================================================

// --- [ETH/SUP OVERLAY] ---
ItemDisplay[ETH]: %GRAY%[ETH] %NAME% %CONTINUE%

// [ELITE] - CORAL High-End
ItemDisplay[UNI ELT]: %SOUNDID-737%%MAP-0B%%DOT-62%%CORAL%[hellYa!Unique] >> %NAME% <<
ItemDisplay[SET ELT]: %SOUNDID-737%%MAP-0B%%DOT-62%%CORAL%[hellYa!Set] >> %NAME% <<
ItemDisplay[RARE ELT]: %TAN%[hellYa!Rare] %NAME%

// [EXCEPTIONAL] - GREEN Mid-Tier
ItemDisplay[UNI EXC]: %SOUNDID-788%%MAP-0B%%DOT-62%%GREEN%[NM.Unique] >> %NAME% <<
ItemDisplay[SET EXC]: %SOUNDID-701%%MAP-0B%%DOT-62%%GREEN%[NM.Set] >> %NAME% <<
ItemDisplay[RARE EXC]: %TAN%[NM.Rare] %NAME%

// [NORMAL] - DARK_GREEN Low-Tier
// Malestrom check: These lines MUST be ABOVE Section 4 (Purge) to show in NM/Hell
ItemDisplay[UNI NORM]: %SOUNDID-788%%MAP-0B%%DARK_GREEN%[n.Unique] %NAME%
ItemDisplay[SET NORM]: %SOUNDID-788%%DARK_GREEN%[n.Set] %NAME%
ItemDisplay[RARE NORM FILTLVL=1]: %TAN%[n.Rare] %NAME%

// =============================================================================
// [7. ACCESSORY ARCHITECT] - TIERED AMULET, RING & CHARM LOGIC
// =============================================================================

// --- [ ABSOLUTE SILENCE BLOCKERS ] ---
// These MUST be at the top of Section 7 to override everything else.
// Logic: If Mode is Night (2) or Hell (3), and ILVL is low/mid, stay silent.
ItemDisplay[FILTLVL>1 (amu OR rin OR CHARM) ILVL<30]:
ItemDisplay[FILTLVL=3 (amu OR rin OR CHARM) ILVL<80]:

// --- [ AMULETS ] ---

// [NORMA TIER: ILVL < 30] - Visible ONLY in MODE 1
ItemDisplay[FILTLVL<2 amu (NMAG OR INF) ILVL<30]: %GRAY%[n.Ammy] %NAME% %TIER-1%
ItemDisplay[FILTLVL<2 amu MAG ILVL<30]: %WHITE%[n.Magic-Ammy] %BLUE%%NAME% %TIER-1%
ItemDisplay[FILTLVL<2 amu RARE ILVL<30]: %WHITE%[n.Rare-Ammy] %YELLOW%%NAME% %TIER-1%

// [NM TIER: ILVL 30-79] - Visible in MODE 1 & 2
ItemDisplay[FILTLVL<3 amu (NMAG OR INF) ILVL>29 ILVL<80]: %GRAY%[NM.Ammy] %NAME% %TIER-2%
ItemDisplay[FILTLVL<3 amu MAG ILVL>29 ILVL<80]: %ORANGE% § [NM.Magic] § %NL%%BLUE%%NAME% L%ILVL% %TIER-2%
ItemDisplay[FILTLVL<3 amu RARE ILVL>29 ILVL<80]: %TAN%§ [NM.Rare] § %NL%%WHITE%%NAME% L%ILVL% %TAN% %TIER-2%

// [hellYa! TIER: ILVL 80-99] - Always Visible
ItemDisplay[amu (NMAG OR INF) ILVL>79]: %GRAY%[hellYa!Base] %NAME% %TIER-9%
ItemDisplay[amu MAG ILVL>79]: %PURPLE% § [hellYa!Magic-NODE] %BLUE%%NAME% %WHITE%L%ILVL% %PURPLE%§{%TAN%Craft at clvl 86+ for +2 Skills%NL%%ORANGE%Caster: P Ame + Ral + Jewel} %TIER-9%
ItemDisplay[amu RARE ILVL>79]: %PURPLE%§ [hellYa!Rare] § %NL%%WHITE%%NAME% L%ILVL% %PURPLE% %TIER-9%

// --- [ RINGS ] ---

// [NORMA TIER: ILVL < 30] - Visible ONLY in MODE 1
ItemDisplay[FILTLVL<2 rin (NMAG OR INF) ILVL<30]: %GRAY%[n.Ring] %NAME% %TIER-1%
ItemDisplay[FILTLVL<2 rin MAG ILVL<30]: %WHITE%[n.Magic-Ring] %BLUE%%NAME% %TIER-1%
ItemDisplay[FILTLVL<2 rin RARE ILVL<30]: %WHITE%[n.Rare-Ring] %YELLOW%%NAME% %TIER-1%

// [NM TIER: ILVL 30-79] - Visible in MODE 1 & 2
ItemDisplay[FILTLVL<3 rin (NMAG OR INF) ILVL>29 ILVL<80]: %GRAY%[NM.Ring] %NAME% %TIER-2%
ItemDisplay[FILTLVL<3 rin MAG ILVL>29 ILVL<80]: %WHITE%[NM.Magic-Ring] %BLUE%%NAME% %TIER-2%
ItemDisplay[FILTLVL<3 rin RARE ILVL>29 ILVL<80]: %WHITE%[NM.Rare-Ring] %YELLOW%%NAME% %TIER-2%

// [hellYa! TIER: ILVL 80-99] - Always Visible
ItemDisplay[rin (NMAG OR INF) ILVL>79]: %GRAY%[hellYa!Base] %NAME% %TIER-9%
ItemDisplay[rin MAG ILVL>79]: %PURPLE% µ [hellYa!Magic-LOOP] %BLUE%%NAME% %WHITE%L%ILVL% %PURPLE%µ %TIER-9%
ItemDisplay[rin RARE ILVL>79]: %PURPLE%§ [hellYa!Rare] § %NL%%WHITE%%NAME% L%ILVL% %PURPLE% %TIER-9%

// --- [ CHARMS ] ---

// [NORMA TIER]
ItemDisplay[FILTLVL<2 cm1 MAG ILVL<30]: %WHITE%· [n.Small-Chip] · %TIER-1%
ItemDisplay[FILTLVL<2 cm2 MAG ILVL<30]: %WHITE%· [n.Large-Chip] · %TIER-1%
ItemDisplay[FILTLVL<2 cm3 MAG ILVL<30]: %WHITE%· [n.Skiller-Chip] · %TIER-1%

// [NM TIER]
