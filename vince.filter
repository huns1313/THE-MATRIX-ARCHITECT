ItemDisplay[FILTLVL<3 (ARMOR OR WEAPON) EXC MAG SOCK>1]: %BLUE%[NM.Magic] %NAME% %RED%[%SOCKETS% SOCK]
ItemDisplay[FILTLVL<3 (ARMOR OR WEAPON) EXC RARE SOCK>1]: %YELLOW%[NM.Rare] %NAME% %RED%[%SOCKETS% SOCK]

// -----------------------------------------------------------------------------
