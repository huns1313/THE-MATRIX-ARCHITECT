// [0. GLOBAL CONFIGURATION & ALIASES]
// =============================================================================
Alias[MODE_NORMA]: 1   
Alias[MODE_NIGHT]: 2   
Alias[MODE_hellYa]: 3  

ItemDisplayFilterName[]: [n.] NORMA MODE
ItemDisplayFilterName[]: [nm.] NIGHT MODE
ItemDisplayFilterName[]: [hellYa!.] HELL MODE

// Re-populating RUNES (Stacked & Unstacked)
Alias[RUNES_NORMA]:  (r01 OR r02 OR r03 OR r04 OR r05 OR r06 OR r07 OR r08 OR r09 OR r01s OR r02s OR r03s OR r04s OR r05s OR r06s OR r07s OR r08s OR r09s)
Alias[RUNES_NIGHT]:  (r10 OR r11 OR r12 OR r13 OR r14 OR r15 OR r16 OR r17 OR r18 OR r10s OR r11s OR r12s OR r13s OR r14s OR r15s OR r16s OR r17s OR r18s)
Alias[RUNES_HELLYA]: (r19 OR r20 OR r21 OR r22 OR r23 OR r24 OR r25 OR r26 OR r27 OR r19s OR r20s OR r21s OR r22s OR r23s OR r24s OR r25s OR r26s OR r27s)
Alias[RUNES_GODLY]:  (r28 OR r29 OR r30 OR r31 OR r32 OR r33 OR r28s OR r29s OR r30s OR r31s OR r32s OR r33s)
// [1. SYSTEM RELEASE NOTES]
// [1. SYSTEM RELEASE NOTES]
// Targets Scroll of Identify (isc) in shops. 
// File MUST be saved in ANSI encoding with HD Text enabled to render these symbols.
ItemDisplay[isc SHOP]: %NAME%{%NAME%%NL%%TEAL%THE §  ¶  †  ‡  µ  ©  ®  ™  «  »   °  •  ·  ×  ¡  ¿  ¹  ²  ³  ¼  ½  ¾  ¢  £  ¥  |  _  · MATRIX%NL%%WHITE%----------------------------%NL%%GREEN%[Ya!!] Tier:%WHITE% Always Visible%NL%%GOLD%[GOD] Tier:%WHITE% Always Visible%NL%%WHITE%----------------------------}


// =============================================================================
// [MASTER QUALITY OVERLAY] - FIRE ONCE
// =============================================================================
ItemDisplay[ETH SUP]: %GRAY%[ETH] %GOLD%[SUP] %NAME% %CONTINUE%
ItemDisplay[ETH !SUP]: %GRAY%[ETH] %NAME% %CONTINUE%
ItemDisplay[!ETH SUP]: %GOLD%[SUP] %NAME% %CONTINUE%

// =============================================================================
// [1. ACCESSORY ARCHITECT] - TIERED AMULET, RING & CHARM LOGIC
// =============================================================================

// --- [ ABSOLUTE SILENCE BLOCKERS ] ---
// These MUST be at the top of Section 7 to override everything else.
// Logic: If Mode is Night (2) or Hell (3), and ILVL is low/mid, stay silent.
ItemDisplay[FILTLVL=3 (amu OR rin OR CHARM) ILVL<80]:
ItemDisplay[FILTLVL>1 (amu OR rin OR CHARM) ILVL<30]:

// --- [ AMULETS ] ---

// [NORMA TIER: ILVL < 30]
// Only show these in Mode 1. In Mode 2/3, they are silenced by the blocker at the top of Section 7.
ItemDisplay[amu ILVL<30 NMAG]: %GRAY%[n.Ammy] %NAME% %TIER-1%
ItemDisplay[amu ILVL<30 MAG]: %WHITE%[n.Magic-Ammy] %BLUE%%NAME% %TIER-1%
ItemDisplay[amu ILVL<30 RARE]: %WHITE%[n.Rare-Ammy] %YELLOW%%NAME% %TIER-1%

// [NM TIER: ILVL 30-79]
// These will show in Mode 1 and 2, but will ALWAYS be named [NM]
ItemDisplay[amu ILVL>29 ILVL<80 NMAG]: %GRAY%[NM.Ammy] %NAME% %TIER-2%
ItemDisplay[amu ILVL>29 ILVL<80 MAG]: %ORANGE% § [NM.Magic] § %NL%%BLUE%%NAME% L%ILVL% %TIER-2%
ItemDisplay[amu ILVL>29 ILVL<80 RARE]: %TAN%§ [NM.Rare] § %NL%%WHITE%%NAME% L%ILVL% %TAN% %TIER-2%

// [Ya!! TIER: ILVL 80-99]
// These will show in ALL modes and ALWAYS be named [Ya!!]
