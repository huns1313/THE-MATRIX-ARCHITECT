// =============================================================================
// [4. REFINED BASE LOGIC] - WEAPONS & ARMOR (2+ SOCKETS ONLY)
// =============================================================================

// -----------------------------------------------------------------------------
// [4.1 QUALITY OVERLAYS (ETH/SUP)] - Tag these first
// -----------------------------------------------------------------------------
ItemDisplay[ETH]: %GRAY%[ETH] %NAME% %CONTINUE%
ItemDisplay[SUP]: %GOLD%[SUP] %NAME% %CONTINUE%

// -----------------------------------------------------------------------------
// [4.2 NORMAL BASES] - VISIBLE ONLY IN [n.] NORMA MODE (FILTLVL 1)
// -----------------------------------------------------------------------------
ItemDisplay[FILTLVL=1 (ARMOR OR WEAPON) NORM NMAG SOCK>1]: %GRAY%[n.Base] %WHITE%%NAME% %RED%[%SOCKETS% SOCK]
ItemDisplay[FILTLVL=1 (ARMOR OR WEAPON) NORM MAG SOCK>1]: %BLUE%[n.Magic] %NAME% %RED%[%SOCKETS% SOCK]
ItemDisplay[FILTLVL=1 (ARMOR OR WEAPON) NORM RARE SOCK>1]: %YELLOW%[n.Rare] %NAME% %RED%[%SOCKETS% SOCK]

// -----------------------------------------------------------------------------
// [4.3 EXCEPTIONAL BASES] - VISIBLE IN [n.] & [nm.] (FILTLVL 1 & 2)
// -----------------------------------------------------------------------------
